    WHERE ACTIVITY_NR IS NOT NULL
      AND OPEN_DATE IS NOT NULL
      AND TO_TIMESTAMP_NTZ(OPEN_DATE / 1000000000) >= '1972-01-01'
      AND TO_TIMESTAMP_NTZ(OPEN_DATE / 1000000000) <= CURRENT_DATE
)

